{
  "name": "lcplot",
  "version": "0.3.0-alpha",
  "description": "高级GIS标绘与量算库 - 支持MIL-STD-2525D图元与通视分析",
  "main": "dist/lcplot.cjs.js",
  "module": "dist/lcplot.esm.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:types": "tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "prepack": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "copy:milsymbol": "mkdir -p libs && cp node_modules/milsymbol/dist/milsymbol.js libs/",
    "postinstall": "npm run copy:milsymbol"
  },
  "keywords": [
    "gis",
    "map",
    "plotting",
    "openlayers",
    "cesium",
    "drawing",
    "measurement"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "cesium": "^1.100.0 || ^1.101.0",
    "ol": "^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/cesium": "^1.70.0",
    "@types/node": "^25.5.0",
    "@types/ol": "^7.0.0",
    "milsymbol": "^3.0.4",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
